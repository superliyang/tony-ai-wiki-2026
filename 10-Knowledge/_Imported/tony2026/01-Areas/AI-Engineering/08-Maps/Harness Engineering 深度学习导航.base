filters:
  or:
    - file.inFolder("01-Areas/AI-Learning/09-Systems")
    - file.inFolder("01-Areas/AI-Engineering/07-Topics")
    - file.inFolder("01-Areas/AI-Engineering/08-Maps")
    - file.inFolder("01-Areas/AI-Engineering/06-Projects/Harness Lab")
formulas:
  note_link: link(file.path, file.name)
  layer: if(file.inFolder("01-Areas/AI-Engineering/06-Projects/Harness Lab"), "项目实践", if(file.inFolder("01-Areas/AI-Engineering/07-Topics"), "工程主题", if(file.inFolder("01-Areas/AI-Engineering/08-Maps"), "工程地图", "系统")))
properties:
  formula.note_link:
    displayName: 笔记
  formula.layer:
    displayName: 层级
  file.path:
    displayName: 路径
  file.mtime:
    displayName: 最近更新
views:
  - type: table
    name: 学习主线
    filters:
      or:
        - file.name == "Harness Engineering"
        - file.name == "MCP 与 CLI 模式"
        - file.name == "Computer Use Runtime and Safety"
        - file.name == "App Server 与 Rich Agent Protocols"
        - file.name == "技能、插件、应用与自动化：Harness 的扩展面"
        - file.name == "Harness 工作流模式：Terminal、Desktop、Cloud 与 Channel"
        - file.name == "Hooks、Cron、CI 与 Background Agents：Harness 自动化闭环"
        - file.name == "Harness 工程案例：Codex、Claude Code、OpenClaw、Gemini CLI"
        - file.name == "Harness 真实工作流对照：Repo、Browser、Recurring Ops 与 Channel"
        - file.name == "Eval Harness 与 Regression Suites"
        - file.name == "Harness Engineering 与 Agent 扩展生态图"
        - file.name == "Harness 工作流与自动化模式图"
    order:
      - formula.layer
      - file.path
  - type: table
    name: 系统样本
    filters:
      or:
        - file.name == "OpenClaw"
        - file.name == "OpenClaw 工作原理与架构"
        - file.name == "OpenClaw 的准自进化工作流"
        - file.name == "OpenClaw 的技能、插件、应用与自动化生态"
        - file.name == "Claude Code"
        - file.name == "Codex"
        - file.name == "Gemini CLI"
        - file.name == "Grok Agent Tools API"
        - file.name == "Kimi"
        - file.name == "Agent 能力扩展对比：OpenClaw、Codex、Claude Code、Gemini CLI、Grok、Kimi"
    order:
      - file.path
  - type: table
    name: 实践层
    filters:
      or:
        - file.name == "项目总览"
        - file.name == "最小 Harness Lab：从 CLI 到 Browser 的学习计划"
        - file.name == "多厂商 Harness 对照实验"
        - file.name == "Harness Lab 第一轮：Repo 修复、Browser 操作与 Daily Ops"
    order:
      - file.path
  - type: table
    name: 导航层
    filters:
      or:
        - file.name == "Harness Engineering 深度学习导航.canvas"
        - file.name == "Harness Engineering 深度学习导航.base"
        - file.name == "Harness Engineering 与 Agent 扩展生态图"
        - file.name == "Harness 工作流与自动化模式图"
        - file.name == "主题索引"
        - file.name == "系统索引"
        - file.name == "地图索引"
        - file.name == "项目索引"
    order:
      - file.path
