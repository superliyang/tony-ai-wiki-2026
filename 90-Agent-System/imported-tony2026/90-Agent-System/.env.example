# Local secret template. Copy values into 90-Agent-System/.env.local.
# .env.local is ignored by Git and should not be committed.

FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# Required only for the WebSocket bot / message receiving path.
FEISHU_APP_ID=
FEISHU_APP_SECRET=

DEEPSEEK_API_KEY=

# Optional. Recommended for stable GitHub release polling and higher API rate limits.
GITHUB_TOKEN=
